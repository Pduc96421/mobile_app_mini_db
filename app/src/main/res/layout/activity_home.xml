<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to MovieHub"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnMovies"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Xem danh sách Movies"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnTheaters"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Xem Theaters"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnShowtimes"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Xem Showtimes"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnTicketHistory"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Lịch sử vé đã đặt"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnProfile"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Login / Profile"
        style="@style/Widget.AppCompat.Button.Colored" />

</LinearLayout>
